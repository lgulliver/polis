MC_HOST=192.168.1.50
MC_PORT=25565
MC_VERSION=
LOG_DIR=logs
DATA_DIR=data

# ── Agent behaviour ────────────────────────────────────────────────────────────
AUTONOMY_ENABLED=false
AUTONOMY_TICK_SECONDS=30

# ── Population ────────────────────────────────────────────────────────────────
# POPULATION_ENABLED=true enables RimWorld-style wanderer arrivals.
# Every WANDERER_ARRIVAL_MINUTES interval there is a 15% chance a wanderer
# with randomly generated trait vector connects to the server.
POPULATION_ENABLED=false
WANDERER_ARRIVAL_MINUTES=10

# ── LLM provider ──────────────────────────────────────────────────────────────
# "ollama"  → fully local, no API key needed (default)
# "openai"  → requires OPENAI_API_KEY below
LLM_PROVIDER=ollama

# Ollama model to use (pulled automatically on first docker compose up)
OLLAMA_MODEL=qwen2.5:7b

# OpenAI (only needed when LLM_PROVIDER=openai)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
